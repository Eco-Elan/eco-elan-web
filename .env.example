# Copy to .env (local) and set the real values in Vercel project settings.
# NEVER commit real keys. Use Stripe TEST keys in development.

# ── Stripe ────────────────────────────────────────────────────────────────
# Client-side publishable key (starts pk_test_ / pk_live_). Exposed to the
# browser at build time by Vite — this is expected and safe.
VITE_STRIPE_PUBLISHABLE_KEY=<your-stripe-publishable-key>

# Server-only secret key (starts sk_test_ / sk_live_). Never expose to the client.
STRIPE_SECRET_KEY=<your-stripe-secret-key>

# Server-only webhook signing secret (starts whsec_) for /api/stripe-webhook.
# From `stripe listen` locally, or the Stripe Dashboard webhook endpoint.
STRIPE_WEBHOOK_SECRET=<your-stripe-webhook-signing-secret>

# ── Resend (contact form + admin document/receipt email) ──────────────────
RESEND_API_KEY=<your-resend-api-key>
# FROM address must be on a domain verified in Resend (e.g. eco-elan.com).
CONTACT_FROM_EMAIL=Eco Elan <noreply@eco-elan.com>
# Inbox that receives contact-form enquiries.
CONTACT_TO_EMAIL=info@eco-elan.com

# ── Supabase (admin console: /ee-admin) ───────────────────────────────────
# Client-side (exposed, safe): used only for staff magic-link auth.
VITE_SUPABASE_URL=<your-supabase-project-url>
VITE_SUPABASE_ANON_KEY=<your-supabase-anon-key>
# Server-only: full DB access from /api/admin/* (NEVER expose to the client).
SUPABASE_URL=<your-supabase-project-url>
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>
# Comma-separated allowlist of staff emails permitted to use the admin console.
ADMIN_EMAILS=owner@eco-elan.com,ops@eco-elan.com

# ── App ────────────────────────────────────────────────────────────────────
# Public site origin — used to build Stripe payment-link redirect URLs.
PUBLIC_BASE_URL=https://www.eco-elan.com
